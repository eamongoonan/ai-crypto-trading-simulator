# Copy this file to .env and fill in your values
# Never commit .env to version control

SECRET_KEY=your-django-secret-key-here

# Optional: set to a PostgreSQL URL to use Postgres instead of SQLite
# e.g. postgresql://user:password@localhost:5432/cryptosim
# DATABASE_URL=

# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Get from https://rapidapi.com/  (Binance Futures Leaderboard API)
RAPIDAPI_KEY=your-rapidapi-key-here

# From https://news.treeofalpha.com/
NEWS_WS_TOKEN=your-news-ws-token-here

# From https://huggingface.co/settings/tokens (free account, read token)
# Without this, news sentiment falls back to keyword-based analysis
HF_API_TOKEN=your-huggingface-token-here
